{
  "env": {
    "name": "credentials",
    "path": "~/develop/credentials/licoproj/.env",
    "env-keys": [
      "MOLTBOOK_API_KEY_ALEXANDRITE",
      "MOLTBOOK_API_KEY_AGATE",
      "LICOPROJ_CREW_PASS_LEONIDAS",
      "LICOPROJ_CREW_PASS_LICO",
      "LICOPROJ_CREW_PASS_IURIA",
      "LICOPROJ_CREW_PASS_POLARIS",
      "LICOPROJ_CREW_PASS_SIRIUS",
      "LICOPROJ_CREW_PASS_AGATE",
      "LICOPROJ_CREW_PASS_ALEXANDRITE"
    ]
  },
  "site_config": {
    "LANG": "C.UTF-8",
    "TZ": "Asia/Tokyo"
  },
  "repos": [
    {
      "name": "licoshdw",
      "hidden": true,
      "source_from": "local",
      "source": {
        "remote": "",
        "local": "../.licoshdw.git"
      }
    },
    {
      "name": "licochron",
      "hidden": false,
      "source_from": "remote",
      "source": {
        "remote": "https://github.com/licosp/licochron.git",
        "local": ".repos/licochron"
      }
    },
    {
      "name": "licochron-history",
      "hidden": false,
      "source_from": "remote",
      "source": {
        "remote": "https://github.com/licosp/licochron-history.git",
        "local": ".repos/licochron-history"
      }
    }
  ],
  "crew": [
    {
      "name": "lico",
      "account": {
        "uid": 1001,
        "gid": 1001,
        "shell": "/bin/bash",
        "sudo": true
      },
      "alias": [
        "leonidas"
      ],
      "worktree": [
        "licoshdw",
        "licochron",
        "licochron-history"
      ]
    },
    {
      "name": "iuria",
      "account": {
        "uid": 1003,
        "gid": 1003,
        "shell": "/bin/bash",
        "sudo": false
      },
      "alias": [
        "leonidas"
      ],
      "worktree": [
        "licoshdw"
      ]
    },
    {
      "name": "polaris",
      "account": {
        "uid": 1004,
        "gid": 1004,
        "shell": "/bin/bash",
        "sudo": false
      },
      "alias": [
        "leonidas"
      ],
      "worktree": [
        "licoshdw"
      ]
    },
    {
      "name": "sirius",
      "account": {
        "uid": 1005,
        "gid": 1005,
        "shell": "/bin/bash",
        "sudo": false
      },
      "alias": [
        "leonidas"
      ],
      "worktree": [
        "licoshdw"
      ]
    },
    {
      "name": "agate",
      "account": {
        "uid": 1006,
        "gid": 1006,
        "shell": "/bin/bash",
        "sudo": false
      },
      "alias": [
        "leonidas"
      ],
      "worktree": [
        "licoshdw"
      ]
    },
    {
      "name": "alexandrite",
      "account": {
        "uid": 1007,
        "gid": 1007,
        "shell": "/bin/bash",
        "sudo": false
      },
      "alias": [
        "leonidas"
      ],
      "worktree": [
        "licoshdw"
      ]
    },
    {
      "name": "leonidas",
      "account": {
        "uid": 1000,
        "gid": 1000,
        "shell": "/bin/bash",
        "sudo": true
      },
      "alias": [
        "lico",
        "iuria",
        "polaris",
        "sirius",
        "agate",
        "alexandrite"
      ],
      "worktree": [
        "licoshdw"
      ]
    }
  ]
}