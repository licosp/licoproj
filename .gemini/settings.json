{
  "context": {
    "fileFiltering": { "respectGitIgnore": false },
    "fileName": ["map.md"],
    "includeDirectories": [
      ".agent/identifiers/agate",
      ".agent/identifiers/alexandrite"
    ]
  },
  "general": {
    "previewFeatures": true,
    "plan": {
      "enabled": true
    }
  },
  "output": {
    "format": "json"
  },
  "security": {
    "blockGitExtensions": true,
    "folderTrust": { "enabled": true },
    "enablePermanentToolApproval": true,
    "disableYoloMode": false
  },
  "skills": { "enabled": true },
  "ui": {
    "showStatusInTitle": true,
    "dynamicWindowTitle": true,
    "hideBanner": true,
    "footer": { "hideContextPercentage": false },
    "showMemoryUsage": false,
    "showCitations": true,
    "showModelInfoInChat": true,
    "useAlternateBuffer": true,
    "errorVerbosity": "full"
  },
  "agents": {
    "overrides": {
      "generalist": {
        "modelConfig": {
          "generateContentConfig": {
            "temperature": 0
          }
        },
        "runConfig": {
          "maxTimeMinutes": 20,
          "maxTurns": 1000
        }
      }
    }
  }
}
