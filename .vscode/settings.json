{
  // Explorer
  "explorer.excludeGitIgnore": false,

  // Work Bench
  "workbench.startupEditor": "none",

  // Editor
  "editor.fontFamily": "UDEV Gothic JPDOC",
  "editor.formatOnSave": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.rulers": [79],
  "editor.wordWrap": "off",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll.shellcheck": "always",
    "source.fixAll.markdownlint": "always"
  },

  // ty
  "ty.configurationFile": ".vscode/ty.toml",

  // SMC
  "scm.diffDecorations": "none",

  // Git
  "git.repositoryScanMaxDepth": 4,

  // * Outside tools
  // Python
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.diagnosticsSource": "Pyright",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["-c", ".vscode/pytest.ini"],
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Ruff
  "ruff.configuration": ".vscode/ruff.toml",
  "ruff.interpreter": ["${workspaceFolder}/.venv/bin/python"],
  "ruff.path": ["${workspaceFolder}/.venv/bin/ruff"],
  "ruff.format.backend": "uv",

  // Prettier
  "prettier.configPath": ".vscode/.prettierrc.yaml",
  "prettier.ignorePath": ".vscode/.prettierignore",
  "prettier.requireConfig": true,

  // Python Test
  "pythonTestExplorer.testFramework": "pytest",

  // ShellCheck
  "shellcheck.customArgs": ["--rcfile=.vscode/.shellcheckrc"],
  "shellcheck.executablePath": "shellcheck",
  "shellcheck.useWorkspaceRootAsCwd": true,

  // Markdownlint
  "markdownlint.configFile": ".vscode/.markdownlint.yaml",
  "markdownlint.run": "onSave",
  "markdownlint.severityForError": "Error",
  "markdownlint.severityForWarning": "Error",

  // * Formatter
  // Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Docker
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },

  // shellformat
  "[bats]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },

  // Python
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  }
}
