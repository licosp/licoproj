{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Game: Start Unified Engine (Python)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "-m",
                "licochron"
            ],
            "options": {
                "env": {
                    "PYTHONPATH": "${workspaceFolder}/packages/licochron/src"
                }
            },
            "problemMatcher": [],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Game: Stop Unified Engine",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "Get-CimInstance Win32_Process -Filter \"Name = 'python.exe'\" | Where-Object { $_.CommandLine -like '*licochron*' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }"
            ],
            "problemMatcher": [],
            "group": "none"
        },
        {
            "label": "Lint: Report to Log",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/Scripts/python.exe -m lico_lint packages > .agent/.internal/workspace/iuria/lint-log.txt 2>&1",
            "problemMatcher": [],
            "group": "none"
        }
    ]
}