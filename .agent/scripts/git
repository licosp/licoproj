#!/bin/bash

# Shim for git to prevent accidental hard resets.
# Managed by: .agent/cards/routine/command-shim-card.md

# Check for "reset" and "--hard" in arguments
HAS_RESET=false
HAS_HARD=false

for arg in "$@"; do
    if [[ "$arg" == "reset" ]]; then
        HAS_RESET=true
    fi
    if [[ "$arg" == "--hard" ]]; then
        HAS_HARD=true
    fi
done

if [[ "$HAS_RESET" == "true" ]] && [[ "$HAS_HARD" == "true" ]]; then
    echo "🚫 [Shim] BLOCKED: 'git reset --hard' is dangerous." >&2
    echo "   (危険なコマンドのためブロックされました)" >&2
    echo "" >&2
    echo "   Alternative / 代替案:" >&2
    echo "   1. Soft Reset:  git reset --soft <commit>" >&2
    echo "   2. Bypass:      /usr/bin/git reset --hard <commit>" >&2
    echo "" >&2
    exit 1
fi

# Fallback to standard git
# WE MUST USE ABSOLUTE PATH TO AVOID RECURSION
exec /usr/bin/git "$@"
